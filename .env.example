# Copy to .env and fill in real values. .env is gitignored.

# Server
PORT=3000
# Comma-separated list of origins allowed to call /api/* from the browser widget.
# e.g. https://theguardiansindia.com,https://www.theguardiansindia.com
ALLOWED_ORIGINS=http://localhost:3000

# Postgres (with pgvector). Local default matches docker-compose.yml.
DATABASE_URL=postgres://guardian:guardian@localhost:5432/guardian

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Admin panel (express-basic-auth)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
